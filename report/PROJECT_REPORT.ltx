\subsection{Key Components}

\textbf{train.py}

\begin{itemize}
    \item Loads dataset from Raw/ai4i2020.csv
    \item Encodes categorical features using LabelEncoder
    \item Scales features using StandardScaler
    \item Trains GradientBoostingClassifier
    \item Saves model artifacts into Models/
\end{itemize}

\textbf{predictor.py}

\begin{itemize}
    \item Loads trained artifacts at startup
    \item Maps raw telemetry into ML feature space
    \item Returns failure probability and risk level
    \item Supports single and batch prediction
\end{itemize}

\textbf{app.py}

\begin{itemize}
    \item Sidebar form for vehicle input
    \item Fleet data table with editing
    \item ML-based risk scoring
    \item Plotly bar chart visualization
    \item AI-generated action cards
\end{itemize}

